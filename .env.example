# Copy this file to .env and fill in real values.
# .env is git-ignored.

# --- Database (TimescaleDB / Postgres) ---
POSTGRES_USER=fabrica
POSTGRES_PASSWORD=change_me_local_only
POSTGRES_DB=fabrica
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# --- MQTT (Mosquitto) ---
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_USER=
MQTT_PASSWORD=

# --- Grafana ---
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# --- Recipe 3: LLM (Orçamentista) ---
# Default provider: anthropic. Switch via lib-comum/llm.py abstraction.
ANTHROPIC_API_KEY=
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-6

# --- Recipe 3: Vector DB (Chroma local) ---
CHROMA_PERSIST_DIR=./receita-3-orcamentista/.chroma

# --- Alerting (Apprise) ---
# Examples — see https://github.com/caronc/apprise
APPRISE_URLS=

# --- Data synthesis seed ---
SYNTH_SEED=20260509
