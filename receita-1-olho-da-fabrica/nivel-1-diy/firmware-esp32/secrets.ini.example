; Copy to secrets.ini and add `extra_configs = secrets.ini` to platformio.ini.
; secrets.ini is git-ignored — it carries credentials that don't belong in a
; public repo.

[env:esp32dev]
build_flags =
    ${env:esp32dev.build_flags}
    -DWIFI_SSID=\"FabricaIoT\"
    -DWIFI_PASSWORD=\"redacted\"
    -DMQTT_BROKER=\"192.168.1.10\"
    -DMQTT_PORT=1883
    -DMACHINE_ID=\"linha-3.maquina-1\"
    -DSENSOR_CALIBRATION_A_PER_V=30.0
