  "panels": [
    {
      "datasource": { "type": "postgres", "uid": "TimescaleDB" },
      "description": "Current draw per machine over the last 8 hours.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineInterpolation": "linear", "lineWidth": 1, "spanNulls": false },
          "unit": "amp"
        },
        "overrides": []
      },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "TimescaleDB" },
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT time_bucket('1 minute', ts) AS time, machine AS metric, AVG(value) AS value FROM telemetry WHERE metric = 'current_a' AND ts > NOW() - INTERVAL '8 hours' GROUP BY 1, machine ORDER BY 1",
          "refId": "A"
        }
      ],
      "title": "Current draw (A) per machine — last 8 h",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "postgres", "uid": "TimescaleDB" },
      "description": "Per-machine state derived from the most recent 5 minutes of telemetry.",
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "auto", "cellOptions": { "type": "color-background" }, "inspect": false },
          "mappings": [
            { "options": { "parado": { "color": "red", "index": 0 } }, "type": "value" },
            { "options": { "em vazio": { "color": "yellow", "index": 1 } }, "type": "value" },
            { "options": { "a produzir": { "color": "green", "index": 2 } }, "type": "value" }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green" }] }
        },
        "overrides": []
      },
      "gridPos": { "h": 11, "w": 12, "x": 0, "y": 9 },
      "id": 2,
      "options": { "cellHeight": "sm", "footer": { "show": false }, "showHeader": true },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "TimescaleDB" },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT machine, CASE WHEN AVG(value) < 0.5 THEN 'parado' WHEN AVG(value) < 2.0 THEN 'em vazio' ELSE 'a produzir' END AS estado, ROUND(AVG(value)::numeric, 2) AS corrente_media_a FROM telemetry WHERE metric = 'current_a' AND ts > NOW() - INTERVAL '5 minutes' GROUP BY machine ORDER BY machine",
          "refId": "A"
        }
      ],
      "title": "Current state per machine (last 5 minutes)",
      "type": "table"
    },
    {
      "datasource": { "type": "postgres", "uid": "TimescaleDB" },
      "description": "Hourly fraction of samples where the machine looked stopped (current < 0.5 A).",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "continuous-RdYlGr" },
          "custom": { "align": "auto", "cellOptions": { "type": "color-background" } },
          "max": 1,
          "min": 0,
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": { "h": 11, "w": 12, "x": 12, "y": 9 },
      "id": 3,
      "options": {
        "calculate": false,
        "cellGap": 1,
        "color": { "mode": "scheme", "scheme": "RdYlGn", "reverse": true },
        "exemplars": { "color": "rgba(255,0,255,0.7)" },
        "filterValues": { "le": 1e-9 },
        "legend": { "show": true },
        "rowsFrame": { "layout": "auto" },
        "tooltip": { "show": true },
        "yAxis": { "axisPlacement": "left", "reverse": false }
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "TimescaleDB" },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT time_bucket('1 hour', ts) AS time, machine, AVG(CASE WHEN value < 0.5 THEN 1.0 ELSE 0.0 END) AS stopped_fraction FROM telemetry WHERE metric = 'current_a' AND ts > NOW() - INTERVAL '24 hours' GROUP BY 1, machine ORDER BY 1, machine",
          "refId": "A"
        }
      ],
      "title": "Stopped fraction per machine — last 24 h",
      "type": "heatmap"
    }
  ],
